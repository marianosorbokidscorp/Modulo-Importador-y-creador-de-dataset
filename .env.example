# Copiá este archivo a .env y completá los valores.
# El .env real está en .gitignore — nunca lo committees.

# --- Power BI ---
# Tenant ID (Azure AD). Usar "common" si no se sabe.
PBI_TENANT_ID=common

# Credenciales de usuario (ROPC flow). Solo funciona si la cuenta NO tiene MFA.
# Si falla, dejá vacío y usá el device code flow desde la UI.
PBI_USERNAME=
PBI_PASSWORD=

# IDs del workspace y dataflow a importar
PBI_WORKSPACE_ID=
PBI_DATAFLOW_ID=

# Client app id (public client). El default del Azure CLI suele funcionar.
PBI_CLIENT_ID=1950a258-227b-4e31-a9cf-717495945fc2
